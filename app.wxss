/* 全局样式 */
page {
  font-size: 28rpx;
  color: #333333;
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

/* Vant 组件覆盖样式 */
.van-card {
  border-radius: 16rpx;
  overflow: hidden;
}

.van-cell-group {
  border-radius: 16rpx;
}

/* 工具类 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background-color: #4A90D9;
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-secondary {
  background-color: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
}
