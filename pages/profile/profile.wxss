/* 个人中心页面 - 暖色设计 */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 50%, #F0E6EF 100%);
  padding: 40rpx 32rpx 80rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
}

/* 内容区域 */
.content {
  padding: 0 24rpx;
  margin-top: -50rpx;
}

/* 用户卡片 */
.user-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3436;
  display: block;
}

.user-desc {
  font-size: 26rpx;
  color: #636E72;
  margin-top: 6rpx;
  display: block;
}

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #F8F9FA;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #636E72;
}

.info-value {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.info-value.highlight {
  color: #FF6B35;
}

/* 用药信息网格 */
.med-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.med-item {
  background-color: #FAF9F7;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.med-item-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
  display: block;
}

.med-item-label {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 8rpx;
  display: block;
}

/* 设置项 */
.setting-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #F8F9FA;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF0EB;
}

.setting-icon.orange {
  background-color: #FFF0EB;
}

.setting-icon.green {
  background-color: #E8F8F0;
}

.setting-text {
  font-size: 28rpx;
  color: #2D3436;
}

.setting-arrow {
  font-size: 28rpx;
  color: #B2BEC3;
}

/* 关于卡片 */
.about-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.about-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.about-version {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-top: 8rpx;
}

.about-desc {
  font-size: 26rpx;
  color: #636E72;
  margin-top: 16rpx;
  line-height: 1.6;
}
