/* 记录页面样式 - 暖色设计 */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 50%, #F0E6EF 100%);
  padding: 40rpx 32rpx 80rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 24rpx;
  margin: -50rpx 24rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #B2BEC3;
  position: relative;
}

.tab.active {
  color: #FF6B35;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #FF6B35;
  border-radius: 2rpx;
}

/* 内容区域 */
.content {
  padding: 0 24rpx;
}

/* 输入卡片 */
.input-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.input-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

/* 输入框组 */
.input-group {
  display: flex;
  align-items: center;
  background-color: #FAF9F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  color: #2D3436;
}

.input-suffix {
  font-size: 28rpx;
  color: #636E72;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  border: none;
}

/* 副作用标签网格 */
.side-effect-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.side-effect-item {
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  background-color: #FAF9F7;
  font-size: 26rpx;
  color: #636E72;
  border: 1px solid #E9ECEF;
}

.side-effect-item.selected {
  background-color: #FFF0EB;
  color: #FF6B35;
  border-color: #FF6B35;
  font-weight: 500;
}

/* 自定义副作用输入 */
.custom-input {
  background-color: #FAF9F7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.custom-input::placeholder {
  color: #B2BEC3;
}

/* 历史记录卡片 */
.history-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #F8F9FA;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 26rpx;
  color: #B2BEC3;
}

.history-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.history-value.highlight {
  color: #FF6B35;
}

/* 副作用标签展示 */
.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.history-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background-color: #FFF0EB;
  color: #FF6B35;
}

/* 空状态 */
.empty-tip {
  display: block;
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #B2BEC3;
}
