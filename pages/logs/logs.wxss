/* 用药日志页面 - 暖色设计 */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 50%, #F0E6EF 100%);
  padding: 40rpx 32rpx 80rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
}

/* 内容区域 */
.content {
  padding: 0 24rpx;
  margin-top: -50rpx;
}

/* 记录卡片 */
.log-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #F8F9FA;
}

.log-item:last-child {
  border-bottom: none;
}

.log-date {
  font-size: 26rpx;
  color: #B2BEC3;
}

.log-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.log-med {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
}

.log-dose {
  font-size: 24rpx;
  color: #FF6B35;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.empty-desc {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-top: 12rpx;
}
