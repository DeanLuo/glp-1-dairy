<view class="page">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="header-title">用药日志</text>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <view class="log-card">
      <view wx:if="{{logs.length === 0}}" class="empty-state">
        <view class="empty-icon">
          <van-icon name="records" size="60rpx" color="#B2BEC3" />
        </view>
        <text class="empty-title">暂无用药日志</text>
        <text class="empty-desc">开始记录您的用药情况</text>
      </view>

      <view class="log-item" wx:for="{{logs}}" wx:key="id">
        <text class="log-date">{{item.date}}</text>
        <view class="log-info">
          <text class="log-med">{{item.medication}}</text>
          <text class="log-dose">{{item.dose}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
