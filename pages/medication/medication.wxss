/* 用药记录页面 - 暖色设计 */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 50%, #F0E6EF 100%);
  padding: 40rpx 32rpx 80rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
}

/* 内容区域 */
.content {
  padding: 0 24rpx;
  margin-top: -50rpx;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 24rpx;
}

/* 药物列表 */
.medication-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medication-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #FAF9F7;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.medication-item.active {
  background-color: #FFF0EB;
  border-color: #FF6B35;
}

.med-item-info {
  flex: 1;
}

.med-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  display: block;
}

.med-dose {
  font-size: 26rpx;
  color: #FF6B35;
  margin-top: 4rpx;
  display: block;
}

.med-freq {
  font-size: 24rpx;
  color: #B2BEC3;
  display: block;
  margin-top: 4rpx;
}

.med-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #E9ECEF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.medication-item.active .med-radio {
  border-color: #FF6B35;
  background-color: #FF6B35;
}

/* 输入组 */
.input-group {
  margin-bottom: 20rpx;
}

.input-label {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background-color: #FAF9F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  box-sizing: border-box;
}

.input-field textarea {
  height: 160rpx;
  padding: 20rpx 24rpx;
  line-height: 1.5;
}

.input-row {
  display: flex;
  align-items: center;
  background-color: #FAF9F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.input-row input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #2D3436;
}

.input-suffix {
  font-size: 28rpx;
  color: #636E72;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 16rpx;
}

.save-btn::after {
  border: none;
}
