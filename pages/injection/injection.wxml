<view class="page">
  <!-- 标题栏 -->
  <view class="title-bar">
    <text class="title">注射记录</text>
    <view class="filter-bar">
      <text class="filter-item {{currentFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</text>
      <text class="filter-item {{currentFilter === '司美格鲁肽' ? 'active' : ''}}" bindtap="setFilter" data-filter="司美格鲁肽">司美</text>
      <text class="filter-item {{currentFilter === '利拉鲁肽' ? 'active' : ''}}" bindtap="setFilter" data-filter="利拉鲁肽">利拉</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="list">
    <view wx:if="{{filteredRecords.length === 0}}" class="empty">
      <text class="empty-text">暂无注射记录</text>
      <text class="empty-hint">点击右下角按钮添加记录</text>
    </view>

    <view class="record" wx:for="{{filteredRecords}}" wx:key="id">
      <!-- 日期标签 -->
      <view class="record-date">
        <text class="date-num">{{item.formattedDate}}</text>
        <text class="date-week">{{item.weekday}}</text>
      </view>

      <!-- 记录内容 -->
      <view class="record-content">
        <view class="record-top">
          <text class="drug-name">{{item.drugName}}</text>
          <text class="dose-tag">{{item.dose}}</text>
        </view>
        <view class="record-info">
          <text class="info-item">第{{item.injectionNumber}}次</text>
          <text class="info-sep">·</text>
          <text class="info-item">{{item.injectionSite}}</text>
          <text class="info-sep">·</text>
          <text class="info-item">{{item.formattedTime}}</text>
        </view>
        <view class="record-note" wx:if="{{item.note}}">
          <text class="note-text">{{item.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="addInjection">
    <van-icon name="plus" size="20px" color="#fff" />
  </view>
</view>
