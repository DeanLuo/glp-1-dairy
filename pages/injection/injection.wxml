<view class="page">
  <!-- Header: Warm gradient hero -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">注射记录</text>
      <text class="header-subtitle">每一次注射都是进步的见证</text>
    </view>
    <view class="header-icon">
      <van-icon name="med-o" size="48rpx" color="#fff" />
    </view>
  </view>

  <!-- Filter tabs -->
  <view class="filter-tabs">
    <scroll-view scroll-x enable-flex class="filter-scroll">
      <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</view>
      <view class="filter-tab {{currentFilter === '司美格鲁肽' ? 'active' : ''}}" bindtap="setFilter" data-filter="司美格鲁肽">司美格鲁肽</view>
      <view class="filter-tab {{currentFilter === '利拉鲁肽' ? 'active' : ''}}" bindtap="setFilter" data-filter="利拉鲁肽">利拉鲁肽</view>
    </scroll-view>
  </view>

  <!-- Records list -->
  <view class="records-container">
    <!-- Empty state -->
    <view wx:if="{{filteredRecords.length === 0}}" class="empty-state">
      <view class="empty-icon">
        <van-icon name="records" size="80rpx" color="#B2BEC3" />
      </view>
      <text class="empty-title">暂无注射记录</text>
      <text class="empty-desc">点击下方按钮记录您的第一次注射</text>
      <van-button type="primary" round size="small" bind:click="addInjection">记录注射</van-button>
    </view>

    <!-- Record cards -->
    <view class="record-card" wx:for="{{filteredRecords}}" wx:key="id">
      <view class="card-header">
        <van-tag type="{{item.drugName === '司美格鲁肽' ? 'warning' : 'primary'}}" round size="medium">{{item.drugName}}</van-tag>
        <text class="injection-number">第{{item.injectionNumber}}次注射</text>
      </view>
      <view class="card-body">
        <view class="detail-row">
          <view class="detail-item">
            <van-icon name="clock-o" size="28rpx" color="#636E72" />
            <text class="detail-label">时间</text>
            <text class="detail-value">{{item.formattedDate}} {{item.formattedTime}}</text>
          </view>
          <view class="detail-item">
            <van-icon name="fire-o" size="28rpx" color="#636E72" />
            <text class="detail-label">剂量</text>
            <text class="detail-value dose">{{item.dose}}</text>
          </view>
        </view>
        <view class="detail-row">
          <view class="detail-item">
            <van-icon name="location-o" size="28rpx" color="#636E72" />
            <text class="detail-label">部位</text>
            <text class="detail-value">{{item.injectionSite}}</text>
          </view>
        </view>
        <view class="detail-note" wx:if="{{item.note}}">
          <text class="note-text">{{item.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Floating action button -->
  <view class="fab" bindtap="addInjection">
    <van-icon name="plus" size="24px" color="#fff" />
  </view>
</view>
