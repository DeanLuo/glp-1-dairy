/* 注射记录页面 - 简洁列表设计 */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 标题栏 */
.title-bar {
  padding: 40rpx 32rpx 24rpx;
  background-color: #FAF9F7;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 24rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #636E72;
  background-color: #ffffff;
}

.filter-item.active {
  background-color: #FF6B35;
  color: #ffffff;
  font-weight: 500;
}

/* 记录列表 */
.list {
  padding: 0 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #2D3436;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-top: 12rpx;
}

/* 单条记录 */
.record {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  gap: 24rpx;
}

/* 日期区域 */
.record-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
  padding-top: 4rpx;
}

.date-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.date-week {
  font-size: 22rpx;
  color: #B2BEC3;
  margin-top: 4rpx;
}

/* 内容区域 */
.record-content {
  flex: 1;
}

.record-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.drug-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.dose-tag {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 500;
  background-color: #FFF4F0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-item {
  font-size: 26rpx;
  color: #636E72;
}

.info-sep {
  color: #B2BEC3;
}

.record-note {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #FAF9F7;
  border-radius: 10rpx;
}

.note-text {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.5;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 60rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}
