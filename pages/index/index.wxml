<view class="page">
  <!-- 顶部背景 -->
  <view class="header">
    <view class="header-content">
      <view class="greeting">
        <text class="greeting-time">{{greeting}}</text>
        <text class="greeting-sub">GLP-1 使用者</text>
      </view>
      <view class="date-badge">
        <text class="date-text">{{currentDate}}</text>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 用药提醒卡片 -->
    <view class="card" wx:if="{{nextDose}}">
      <view class="card-header">
        <text class="card-title">下次用药</text>
        <van-tag type="primary" size="medium">{{nextDose.medication}}</van-tag>
        <van-tag type="success" size="medium">{{nextDose.dose}}</van-tag>
      </view>
      <view class="card-body">
        <view class="dose-info">
          <van-icon name="clock-o" size="18px" color="#666" />
          <text class="dose-time">{{nextDose.time}}</text>
        </view>
        <van-button type="primary" size="small" round bind:click="goToMedication">立即记录</van-button>
      </view>
    </view>

    <!-- 快捷记录 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">快捷记录</text>
      </view>
      <view class="quick-actions">
        <view class="action-item" bindtap="goToPage" data-path="/pages/medication/medication">
          <view class="action-icon" style="background-color:#E8F4FF">
            <van-icon name="plus" size="24px" color="#4A90D9" />
          </view>
          <text class="action-text">用药记录</text>
        </view>
        <view class="action-item" bindtap="goToPage" data-path="/pages/records/records">
          <view class="action-icon" style="background-color:#E8F8F0">
            <van-icon name="chart-trending-o" size="24px" color="#07c160" />
          </view>
          <text class="action-text">体重记录</text>
        </view>
        <view class="action-item" bindtap="goToPage" data-path="/pages/records/records">
          <view class="action-icon" style="background-color:#FFF4E8">
            <van-icon name="warning-o" size="24px" color="#ff976a" />
          </view>
          <text class="action-text">副作用</text>
        </view>
      </view>
    </view>

    <!-- 体重数据 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">体重追踪</text>
      </view>
      <view class="data-row">
        <view class="data-item">
          <text class="data-value">{{currentWeight || '--'}}</text>
          <text class="data-label">当前 kg</text>
        </view>
        <view class="data-item">
          <text class="data-value" style="color:{{weightChange <= 0 ? '#07c160' : '#ee0a24'}}">{{weightChange || '0'}}</text>
          <text class="data-label">本周变化 kg</text>
        </view>
        <view class="data-item">
          <text class="data-value">{{targetWeight || '--'}}</text>
          <text class="data-label">目标 kg</text>
        </view>
      </view>
      <view class="progress-section">
        <van-progress color="#4A90D9" percentage="{{progressPercent || 0}}" show-pivot="{{true}}" />
      </view>
    </view>

    <!-- 统计 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">本周统计</text>
      </view>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-value">{{medicationCount || 0}}</text>
          <text class="stat-label">用药次数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{sideEffectCount || 0}}</text>
          <text class="stat-label">副作用记录</text>
        </view>
      </view>
    </view>
  </view>
</view>
