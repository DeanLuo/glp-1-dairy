<view class="page">
  <!-- 顶部问候区 -->
  <view class="hero">
    <view class="hero-top">
      <view class="user-info">
        <view class="avatar-ring">
          <text class="avatar-initial">{{userInitial}}</text>
        </view>
        <view class="greeting-block">
          <text class="greeting-time">{{greeting}}</text>
          <text class="greeting-name">{{userName}}</text>
        </view>
      </view>
      <view class="date-pill">
        <text class="date-text">{{currentDate}}</text>
      </view>
    </view>
  </view>

  <!-- 主内容 -->
  <view class="content">
    <!-- 用药提醒 -->
    <view class="reminder-card" wx:if="{{nextDose}}">
      <view class="reminder-left">
        <view class="reminder-icon">
          <van-icon name="clock-o" size="28px" color="#fff" />
        </view>
        <view class="reminder-info">
          <text class="reminder-label">下次用药</text>
          <text class="reminder-med">{{nextDose.medication}} · {{nextDose.dose}}</text>
        </view>
      </view>
      <view class="reminder-right">
        <text class="reminder-time">{{nextDose.time}}</text>
        <van-button size="mini" round type="primary" bind:click="goToMedication">记录</van-button>
      </view>
    </view>

    <!-- 体重追踪 -->
    <view class="weight-section">
      <view class="section-header">
        <text class="section-title">体重记录</text>
        <text class="section-link" bindtap="goToRecords">查看全部 ></text>
      </view>
      <view class="weight-card" bindtap="goToRecords">
        <view class="weight-main">
          <view class="weight-current">
            <text class="weight-value">{{currentWeight || '--'}}</text>
            <text class="weight-unit">kg</text>
          </view>
          <view class="weight-change {{weightChange <= 0 ? 'positive' : 'negative'}}">
            <van-icon name="{{weightChange <= 0 ? 'arrow-down' : 'arrow-up'}}" size="14px" />
            <text class="change-value">{{weightChange ? (weightChange > 0 ? '+' : '') + weightChange : '0'}} kg</text>
          </view>
        </view>
        <view class="weight-progress-wrap">
          <view class="progress-labels">
            <text class="progress-label">目标 {{targetWeight || '--'}} kg</text>
            <text class="progress-percent">{{progressPercent || 0}}%</text>
          </view>
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{progressPercent || 0}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷记录 -->
    <view class="quick-section">
      <text class="section-title">快捷记录</text>
      <view class="quick-grid">
        <view class="quick-item" bindtap="goToMedication">
          <view class="quick-icon" style="background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%)">
            <van-icon name="plus" size="22px" color="#fff" />
          </view>
          <text class="quick-text">用药</text>
        </view>
        <view class="quick-item" bindtap="goToRecords">
          <view class="quick-icon" style="background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%)">
            <van-icon name="chart-trending-o" size="22px" color="#fff" />
          </view>
          <text class="quick-text">体重</text>
        </view>
        <view class="quick-item" bindtap="goToRecords">
          <view class="quick-icon" style="background: linear-gradient(135deg, #A8E6CF 0%, #7FCDBB 100%)">
            <van-icon name="warning-o" size="22px" color="#fff" />
          </view>
          <text class="quick-text">副作用</text>
        </view>
      </view>
    </view>

    <!-- 本周统计 -->
    <view class="stats-section">
      <text class="section-title">本周小结</text>
      <view class="stats-row">
        <view class="stat-card">
          <text class="stat-number">{{medicationCount || 0}}</text>
          <text class="stat-desc">次用药</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{sideEffectCount || 0}}</text>
          <text class="stat-desc">次副作用</text>
        </view>
      </view>
    </view>
  </view>
</view>
