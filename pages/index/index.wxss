/* 首页样式 - Warm & Personal Design */
page {
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAF9F7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部区域 - 温暖渐变 */
.hero {
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 50%, #F0E6EF 100%);
  padding: 50rpx 32rpx 140rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-ring {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
}

.avatar-initial {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.greeting-block {
  display: flex;
  flex-direction: column;
}

.greeting-time {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: -0.5rpx;
}

.greeting-name {
  font-size: 26rpx;
  color: #636E72;
  margin-top: 4rpx;
}

/* 日期标签 */
.date-pill {
  background-color: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.5);
}

.date-text {
  font-size: 24rpx;
  color: #636E72;
}

/* 主内容区 */
.content {
  padding: 0 24rpx;
  margin-top: -100rpx;
}

/* 用药提醒卡片 - 突出设计 */
.reminder-card {
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B35 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.35);
}

.reminder-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.reminder-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reminder-info {
  display: flex;
  flex-direction: column;
}

.reminder-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.reminder-med {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 4rpx;
}

.reminder-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.reminder-time {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.section-link {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* 体重卡片 */
.weight-section {
  margin-bottom: 32rpx;
}

.weight-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.weight-main {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.weight-current {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.weight-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: -2rpx;
}

.weight-unit {
  font-size: 28rpx;
  color: #636E72;
}

.weight-change {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.weight-change.positive {
  background-color: #F0FFF4;
  color: #07c160;
}

.weight-change.negative {
  background-color: #FFF5F5;
  color: #ee0a24;
}

.change-value {
  margin-left: 4rpx;
}

/* 进度条 */
.weight-progress-wrap {
  background-color: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #B2BEC3;
}

.progress-percent {
  font-size: 22rpx;
  color: #636E72;
  font-weight: 500;
}

.progress-bar {
  height: 10rpx;
  background-color: #E9ECEF;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9A56 0%, #FF6B35 100%);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

/* 快捷记录 */
.quick-section {
  margin-bottom: 32rpx;
}

.quick-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.quick-text {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

/* 统计区块 */
.stats-section {
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.stat-card {
  flex: 1;
  background: linear-gradient(160deg, #FFE5D9 0%, #FFCAD4 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  text-align: center;
}

.stat-card:nth-child(2) {
  background: linear-gradient(160deg, #E8F4FF 0%, #D4E5FF 100%);
}

.stat-number {
  font-size: 52rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
}

.stat-desc {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 8rpx;
  display: block;
}
